<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="edukids" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.edukids.edukids3a.model.Evenement</class>
        <class>com.edukids.edukids3a.model.Programme</class>
        <class>com.edukids.edukids3a.model.User</class>
        <class>com.edukids.edukids3a.model.Message</class>
        <class>com.edukids.edukids3a.model.Conversation</class>
        <class>com.edukids.edukids3a.model.ConversationParticipant</class>
        <class>com.edukids.edukids3a.model.TypeEvenement</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3308/edukids?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC&amp;characterEncoding=UTF-8&amp;connectTimeout=8000&amp;socketTimeout=45000&amp;autoReconnect=true&amp;maxReconnects=3"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.jdbc.time_zone" value="UTC"/>
            <property name="hibernate.connection.autocommit" value="true"/>
            <property name="hibernate.connection.pool_size" value="10"/>
        </properties>
    </persistence-unit>
</persistence>
