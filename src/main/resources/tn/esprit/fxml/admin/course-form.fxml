<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin.CourseFormController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="22.0" styleClass="eduport-page">
                    <padding>
                        <Insets bottom="28.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="eduport-strip">
                            <padding>
                                <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                            </padding>
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="eduport-brand" text="EduKids" />
                                        <Label styleClass="eduport-mini-text" text="Instructor style editor" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Course List" />
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <VBox spacing="8.0" styleClass="eduport-hero-card">
                                            <padding>
                                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                            </padding>
                                            <children>
                                                <Label fx:id="badgeLabel" styleClass="hero-badge" text="Create Course" />
                                                <Label fx:id="pageTitleLabel" styleClass="hero-title" text="Launch a new EduKids course" wrapText="true" />
                                                <Label fx:id="pageSubtitleLabel" styleClass="hero-text" text="Use a dedicated page to prepare the course details before publishing them to the EduKids database." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="16.0" styleClass="eduport-form-card">
                                            <padding>
                                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Course Details" />
                                                <Label styleClass="section-subtitle" text="Fill in the content below. The preview card on the right updates as you type." />
                                                <GridPane hgap="16.0" vgap="14.0">
                                                    <children>
                                                        <Label text="Course Title" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                        <TextField fx:id="titleField" promptText="Example: Mathematics 6th Grade" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                        <Label text="Subject" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                        <TextField fx:id="subjectField" promptText="Example: Mathematics" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                        <Label text="Level" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                        <ComboBox fx:id="levelComboBox" prefWidth="220.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                        <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                        <ComboBox fx:id="statusComboBox" prefWidth="220.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                        <Label text="Description" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                        <TextArea fx:id="descriptionArea" prefRowCount="7" promptText="Describe the objectives, the audience, and the learning outcomes." GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                                        <Label text="AI Tools" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                                        <VBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                                            <children>
                                                                <HBox spacing="10.0">
                                                                    <children>
                                                                        <Button fx:id="generateDescriptionButton" mnemonicParsing="false" onAction="#handleGenerateDescription" styleClass="secondary-button" text="Generate Description" />
                                                                        <Button fx:id="suggestObjectivesButton" mnemonicParsing="false" onAction="#handleSuggestObjectives" styleClass="secondary-button" text="Suggest Objectives" />
                                                                    </children>
                                                                </HBox>
                                                                <HBox spacing="10.0">
                                                                    <children>
                                                                        <ComboBox fx:id="translationLanguageComboBox" prefWidth="160.0" />
                                                                        <Button fx:id="translateButton" mnemonicParsing="false" onAction="#handleTranslateCourse" styleClass="ghost-button" text="Translate" />
                                                                    </children>
                                                                </HBox>
                                                                <Button fx:id="generateImageButton" mnemonicParsing="false" onAction="#handleGenerateImage" styleClass="primary-button" text="Generate Cover Image" />
                                                                <Label fx:id="aiStatusLabel" text="AI assistant ready." wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                    <columnConstraints>
                                                        <javafx.scene.layout.ColumnConstraints minWidth="120.0" />
                                                        <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" />
                                                    </columnConstraints>
                                                </GridPane>
                                                <HBox spacing="12.0">
                                                    <children>
                                                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSaveCourse" styleClass="primary-button" text="Submit Course" />
                                                        <Button mnemonicParsing="false" onAction="#handleResetForm" styleClass="secondary-button" text="Reset" />
                                                        <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="ghost-button" text="Cancel" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="320.0" spacing="18.0">
                                    <children>
                                        <VBox spacing="10.0" styleClass="preview-card">
                                            <padding>
                                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="preview-kicker" text="Live Preview" />
                                                <Label fx:id="previewImageStatusLabel" styleClass="preview-image-status" text="No cover image generated yet." wrapText="true" />
                                                <ImageView fx:id="previewImageView" fitHeight="168.0" fitWidth="276.0" managed="false" pickOnBounds="true" preserveRatio="true" smooth="true" styleClass="preview-cover-image" visible="false" />
                                                <Label fx:id="previewTitleLabel" styleClass="preview-title" text="Your course title will appear here" wrapText="true" />
                                                <HBox spacing="8.0">
                                                    <children>
                                                        <Label fx:id="previewSubjectLabel" styleClass="preview-chip" text="Select a subject" />
                                                        <Label fx:id="previewLevelLabel" styleClass="preview-chip-alt" text="Niveau 1" />
                                                        <Label fx:id="previewStatusLabel" styleClass="lesson-chip-dark" text="Draft" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="previewDescriptionLabel" styleClass="hero-text" text="A short and engaging summary will help parents and students understand the value of the course." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0" styleClass="footer-mini-card">
                                            <padding>
                                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Publishing Tips" />
                                                <Label styleClass="hero-text" text="Use a clear title, a short subject label, and a description focused on outcomes and audience." wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="60.0" styleClass="eduport-footer">
                            <padding>
                                <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
                            </padding>
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="footer-title" text="EduKids" />
                                        <Label styleClass="footer-text" text="A JavaFX admin workspace for managing EduKids content." wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="footer-title" text="Workflow" />
                                        <Label styleClass="footer-link" text="Create page" />
                                        <Label styleClass="footer-link" text="Edit page" />
                                        <Label styleClass="footer-link" text="Success page" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="footer-title" text="Database" />
                                        <Label styleClass="footer-link" text="EduKids courses" />
                                        <Label styleClass="footer-link" text="EduKids lessons" />
                                        <Label styleClass="footer-link" text="Student progress" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
