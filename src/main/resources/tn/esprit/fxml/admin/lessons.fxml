<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="admin-page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin.LessonController">
    <children>
        <VBox AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="26.0" AnchorPane.rightAnchor="26.0" AnchorPane.topAnchor="18.0" spacing="16.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="page-kicker" text="Lesson management" />
                                <Label styleClass="page-hero-title" text="Lessons" />
                                <Label styleClass="page-hero-subtitle" text="Browse every lesson by default, then refine the list with course filter, smart search, and sorting." wrapText="true" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button minWidth="126.0" mnemonicParsing="false" onAction="#handleRefreshLessons" prefWidth="126.0" styleClass="toolbar-refresh-button" text="Refresh" />
                        <Button fx:id="createButton" minWidth="196.0" mnemonicParsing="false" onAction="#handleCreateLesson" prefWidth="196.0" styleClass="toolbar-create-button" text="Create a Lesson" />
                    </children>
                </HBox>

                <HBox spacing="14.0">
                    <children>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="metric-card-blue" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
                            </padding>
                            <children>
                                <Label styleClass="metric-title" text="Total Lessons" />
                                <Label fx:id="totalLessonsMetricLabel" styleClass="metric-value-blue" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="metric-card-green" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
                            </padding>
                            <children>
                                <Label styleClass="metric-title" text="PDF Resources" />
                                <Label fx:id="pdfLessonsMetricLabel" styleClass="metric-value-green" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="metric-card-gold" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
                            </padding>
                            <children>
                                <Label styleClass="metric-title" text="Video or YouTube" />
                                <Label fx:id="videoLessonsMetricLabel" styleClass="metric-value-gold" text="0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="14.0" styleClass="admin-table-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="16.0" left="18.0" right="18.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="table-toolbar">
                            <children>
                                <TextField fx:id="searchField" promptText="Search by lesson, course, media, or ID" styleClass="toolbar-search-field" HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="courseComboBox" prefWidth="230.0" styleClass="toolbar-combo-box" />
                                <ComboBox fx:id="sortComboBox" prefWidth="220.0" styleClass="toolbar-combo-box" />
                                <Button minWidth="150.0" mnemonicParsing="false" onAction="#handleEditLesson" prefWidth="150.0" styleClass="table-edit-button" text="Edit Selected" />
                                <Button minWidth="176.0" mnemonicParsing="false" onAction="#handleDeleteLesson" prefWidth="176.0" styleClass="table-delete-button" text="Delete Selected" />
                            </children>
                        </HBox>

                        <TableView fx:id="lessonTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                                <TableColumn fx:id="orderColumn" prefWidth="90.0" text="Order" />
                                <TableColumn fx:id="titleColumn" prefWidth="260.0" text="Lesson Title" />
                                <TableColumn fx:id="courseColumn" prefWidth="220.0" text="Course" />
                                <TableColumn fx:id="mediaTypeColumn" prefWidth="170.0" text="Media" />
                                <TableColumn fx:id="urlColumn" prefWidth="420.0" text="Resource Links" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label fx:id="pageSummaryLabel" styleClass="pagination-summary" text="Showing 0 of 0 entries" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox fx:id="paginationBox" alignment="CENTER_RIGHT" spacing="8.0" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
