<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin.LessonFormController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="22.0" styleClass="eduport-page">
                    <padding>
                        <Insets bottom="28.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="eduport-strip">
                            <padding>
                                <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                            </padding>
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="eduport-brand" text="EduKids" />
                                        <Label styleClass="eduport-mini-text" text="Lesson editor" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Lesson List" />
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <VBox spacing="8.0" styleClass="eduport-hero-card">
                                            <padding>
                                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                            </padding>
                                            <children>
                                                <Label fx:id="badgeLabel" styleClass="hero-badge" text="Create Lesson" />
                                                <Label fx:id="pageTitleLabel" styleClass="hero-title" text="Build a lesson on its own dedicated page" wrapText="true" />
                                                <Label fx:id="pageSubtitleLabel" styleClass="hero-text" text="Use the same editor style to prepare the lesson, choose its course, and save it to EduKids." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="16.0" styleClass="eduport-form-card">
                                            <padding>
                                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Lesson Details" />
                                                <Label styleClass="section-subtitle" text="Fill the lesson content below. The preview card on the right updates as you type." />
                                                <GridPane hgap="16.0" vgap="14.0">
                                                    <children>
                                                        <Label text="Course" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                        <ComboBox fx:id="courseComboBox" prefWidth="320.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                        <Label text="Lesson Title" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                        <TextField fx:id="lessonTitleField" promptText="Example: Introduction to Fractions" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                        <Label text="Order" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                        <TextField fx:id="orderField" promptText="1" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                        <Label text="PDF / Main URL" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                        <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                                            <children>
                                                                <TextField fx:id="pdfUrlField" promptText="https://example.com/file.pdf" HBox.hgrow="ALWAYS" />
                                                                <Button mnemonicParsing="false" onAction="#handleChoosePdfFile" styleClass="secondary-button" text="Choose PDF" />
                                                            </children>
                                                        </HBox>
                                                        <Label text="Video URL" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                        <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                                            <children>
                                                                <TextField fx:id="videoUrlField" promptText="https://example.com/video.mp4" HBox.hgrow="ALWAYS" />
                                                                <Button mnemonicParsing="false" onAction="#handleChooseVideoFile" styleClass="secondary-button" text="Choose Video" />
                                                            </children>
                                                        </HBox>
                                                        <Label text="YouTube URL" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                                        <TextField fx:id="youtubeUrlField" promptText="https://youtube.com/watch?v=..." GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                                    </children>
                                                    <columnConstraints>
                                                        <javafx.scene.layout.ColumnConstraints minWidth="130.0" />
                                                        <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" />
                                                    </columnConstraints>
                                                </GridPane>
                                                <HBox spacing="12.0">
                                                    <children>
                                                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSaveLesson" styleClass="primary-button" text="Submit Lesson" />
                                                        <Button mnemonicParsing="false" onAction="#handleResetForm" styleClass="secondary-button" text="Reset" />
                                                        <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="ghost-button" text="Cancel" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="320.0" spacing="18.0">
                                    <children>
                                        <VBox spacing="10.0" styleClass="lesson-preview-card">
                                            <padding>
                                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="preview-kicker" text="Live Preview" />
                                                <Label fx:id="previewLessonTitleLabel" styleClass="preview-title" text="Your lesson title will appear here" wrapText="true" />
                                                <Label fx:id="previewCourseLabel" styleClass="preview-chip" text="Select a course" />
                                                <HBox spacing="8.0">
                                                    <children>
                                                        <Label fx:id="previewOrderLabel" styleClass="preview-chip-alt" text="Lesson 1" />
                                                        <Label fx:id="previewMediaLabel" styleClass="lesson-chip-dark" text="MEDIA" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="previewUrlLabel" styleClass="hero-text" text="Add one or more lesson links here." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0" styleClass="footer-mini-card">
                                            <padding>
                                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Publishing Tips" />
                                                <Label styleClass="hero-text" text="Keep lesson order clean so students see the right sequence inside the selected course." wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="60.0" styleClass="eduport-footer">
                            <padding>
                                <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
                            </padding>
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="footer-title" text="EduKids" />
                                        <Label styleClass="footer-text" text="A lesson workflow integrated into the same JavaFX admin style." wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="footer-title" text="Workflow" />
                                        <Label styleClass="footer-link" text="Lesson list" />
                                        <Label styleClass="footer-link" text="Create page" />
                                        <Label styleClass="footer-link" text="Edit page" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="footer-title" text="Media" />
                                        <Label styleClass="footer-link" text="PDF link" />
                                        <Label styleClass="footer-link" text="Video link" />
                                        <Label styleClass="footer-link" text="YouTube link" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
