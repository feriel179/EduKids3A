<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.edukids.edukids3a.controller.GroupMembersDialogController"
            stylesheets="@../../css/chat.css"
            styleClass="chat-dialog-root">
    <center>
        <VBox styleClass="chat-dialog-card" spacing="16">
            <VBox spacing="4">
                <Label fx:id="lblDialogTitle" text="Gestion des membres" styleClass="chat-dialog-title"/>
                <Label fx:id="lblDialogSubtitle" text="Ajouter ou supprimer des membres du groupe."
                       wrapText="true" styleClass="chat-dialog-subtitle"/>
            </VBox>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="chat-dialog-tabs">
                <Tab fx:id="tabAdd" text="Ajouter">
                    <VBox spacing="12" styleClass="chat-dialog-tab-content">
                        <Label text="Recherche par nom ou email" styleClass="chat-dialog-section-title"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="tfAddSearch" promptText="Nom ou email..."
                                       styleClass="chat-search-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <ListView fx:id="lvAddResults" VBox.vgrow="ALWAYS" prefHeight="260"
                                  styleClass="chat-user-results">
                            <placeholder>
                                <Label text="Tapez pour rechercher un membre à ajouter."
                                       wrapText="true" styleClass="chat-empty-inline"/>
                            </placeholder>
                        </ListView>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="Fermer" onAction="#onClose" styleClass="button-ghost"/>
                            <Button fx:id="btnAddSelected" text="Ajouter le membre" onAction="#onAddSelected"
                                    styleClass="button-primary"/>
                        </HBox>
                    </VBox>
                </Tab>
                <Tab fx:id="tabRemove" text="Supprimer">
                    <VBox spacing="12" styleClass="chat-dialog-tab-content">
                        <Label text="Membres du groupe" styleClass="chat-dialog-section-title"/>
                        <ListView fx:id="lvGroupMembers" VBox.vgrow="ALWAYS" prefHeight="260"
                                  styleClass="chat-user-results">
                            <placeholder>
                                <Label text="Aucun membre à afficher." wrapText="true" styleClass="chat-empty-inline"/>
                            </placeholder>
                        </ListView>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="Fermer" onAction="#onClose" styleClass="button-ghost"/>
                            <Button fx:id="btnRemoveSelected" text="Supprimer le membre" onAction="#onRemoveSelected"
                                    styleClass="button-danger"/>
                        </HBox>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </center>
</BorderPane>
