<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1200.0" styleClass="login-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.LoginController">
    <children>
        <VBox alignment="CENTER_LEFT" layoutX="390.0" layoutY="145.0" prefWidth="420.0" spacing="16.0" styleClass="card">
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
            </padding>
            <children>
                <Label styleClass="page-title" text="CourseApp" />
                <Label styleClass="section-subtitle" text="Choose a role and connect the app to EduKids data." />
                <Label text="Role" />
                <ComboBox fx:id="roleComboBox" prefWidth="356.0" />
                <Label fx:id="studentNameLabel" text="Student Name or Email" />
                <TextField fx:id="studentNameField" promptText="Enter your name or email" />
                <Button mnemonicParsing="false" onAction="#handleLogin" prefWidth="356.0" styleClass="primary-button" text="Continue" />
            </children>
        </VBox>
    </children>
</AnchorPane>
