<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.student.CourseDetailController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="student-detail-scroll" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="18.0">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <StackPane fx:id="courseHeroPane" maxHeight="270.0" minHeight="270.0" prefHeight="270.0" styleClass="student-detail-hero">
                            <children>
                                <ImageView fx:id="courseImageView" managed="false" pickOnBounds="true" preserveRatio="false" smooth="true" visible="false" />
                                <Region styleClass="student-detail-hero-overlay" />
                                <VBox alignment="BOTTOM_LEFT" spacing="16.0" StackPane.alignment="BOTTOM_LEFT">
                                    <padding>
                                        <Insets bottom="26.0" left="28.0" right="28.0" top="26.0" />
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="subjectLabel" styleClass="student-course-chip" text="Subject" />
                                                <Label fx:id="courseIdLabel" styleClass="student-course-chip-muted" text="Course #0" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="courseTitleLabel" styleClass="student-detail-title" text="Course Title" wrapText="true" />
                                        <Label fx:id="courseSummaryLabel" styleClass="student-detail-summary" text="Course summary" wrapText="true" />
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="levelBadgeLabel" styleClass="level-badge" text="Level" />
                                                <Label fx:id="lessonCountLabel" styleClass="student-detail-stat-badge" text="0 lessons" />
                                                <Label fx:id="durationLabel" styleClass="student-detail-stat-badge" text="0 min" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <Label fx:id="courseInitialsLabel" styleClass="student-detail-hero-initials" text="ED" StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets right="24.0" top="24.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>
                        <VBox spacing="10.0" styleClass="student-detail-section">
                            <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
                            <children>
                                <Label styleClass="section-title" text="Description" />
                                <Label fx:id="descriptionLabel" styleClass="student-detail-description" text="Description" wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="10.0" styleClass="student-detail-section">
                            <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="section-title" text="Lessons" />
                                    </children>
                                </HBox>
                                <Label styleClass="student-detail-section-subtitle" text="Open each lesson, then continue to the exercise studio to draw and write." wrapText="true" />
                                <VBox fx:id="lessonContainer" spacing="14.0" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
