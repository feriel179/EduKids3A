<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.student.CourseDetailController">
    <children>
        <VBox AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0" spacing="18.0">
            <children>
                <Label fx:id="courseTitleLabel" styleClass="page-title" text="Course Title" />
                <HBox spacing="10.0">
                    <children>
                        <Label fx:id="subjectLabel" styleClass="muted-label" text="Subject" />
                        <Label fx:id="levelBadgeLabel" styleClass="level-badge" text="Level" />
                    </children>
                </HBox>
                <VBox spacing="10.0" styleClass="card">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="section-title" text="Description" />
                        <Label fx:id="descriptionLabel" styleClass="muted-label" text="Description" wrapText="true" />
                    </children>
                </VBox>
                <VBox spacing="10.0" styleClass="card" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="section-title" text="Lessons" />
                        <Label styleClass="muted-label" text="Open the PDF, video, or YouTube resource for each lesson." wrapText="true" />
                        <ListView fx:id="lessonListView" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
