<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.student.ProfileController">
    <children>
        <VBox AnchorPane.leftAnchor="24.0" AnchorPane.topAnchor="24.0" spacing="18.0">
            <children>
                <Label styleClass="page-title" text="Student Profile" />
                <VBox spacing="14.0" styleClass="card">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                    <children>
                        <Label styleClass="section-title" text="Personal Information" />
                        <Label text="Name" />
                        <Label fx:id="nameLabel" styleClass="profile-value" text="-" />
                        <Label text="Email" />
                        <Label fx:id="emailLabel" styleClass="profile-value" text="-" />
                        <Label text="Age Group" />
                        <Label fx:id="ageSummaryLabel" styleClass="profile-value" text="Ages 8-10" />
                        <Label text="Preferred Category" />
                        <Label fx:id="categorySummaryLabel" styleClass="profile-value" text="General" />
                        <Label text="Enrolled Courses" />
                        <Label fx:id="coursesCountLabel" styleClass="profile-value" text="0" />
                        <Label text="Update Age" />
                        <ComboBox fx:id="ageComboBox" prefWidth="260.0" />
                        <Label text="Update Preferred Category" />
                        <ComboBox fx:id="preferredCategoryComboBox" prefWidth="260.0" />
                        <Button fx:id="saveProfileButton" mnemonicParsing="false" onAction="#handleSaveProfile" styleClass="primary-button" text="Save Profile" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
