<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.student.MyCourseController">
    <children>
        <VBox AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="16.0" AnchorPane.rightAnchor="16.0" AnchorPane.topAnchor="16.0" spacing="18.0" styleClass="my-courses-page">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="page-title" text="My Courses" />
                                <Label styleClass="section-subtitle" text="All courses currently added to your personal learning list." />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="8.0">
                            <children>
                                <Label fx:id="savedCountLabel" styleClass="student-mini-badge" text="0 courses" />
                                <Label fx:id="savedDurationLabel" styleClass="student-mini-badge" text="0 min" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
                <HBox spacing="16.0" styleClass="my-course-stats-row">
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="6.0" styleClass="my-course-stat-card my-course-stat-primary">
                            <children>
                                <Label styleClass="my-course-stat-title" text="Courses Read" />
                                <Label fx:id="coursesReadPercentLabel" styleClass="my-course-stat-value my-course-stat-value-primary" text="0%" />
                                <Label fx:id="coursesReadMetaLabel" styleClass="my-course-stat-meta" text="0 of 0 courses read" wrapText="true" />
                            </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="6.0" styleClass="my-course-stat-card">
                            <children>
                                <Label styleClass="my-course-stat-title" text="Completed" />
                                <Label fx:id="completedCoursesValueLabel" styleClass="my-course-stat-value" text="0/0" />
                                <Label fx:id="completedCoursesMetaLabel" styleClass="my-course-stat-meta" text="courses completed" wrapText="true" />
                            </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="6.0" styleClass="my-course-stat-card">
                            <children>
                                <Label styleClass="my-course-stat-title" text="Remaining" />
                                <Label fx:id="remainingCoursesValueLabel" styleClass="my-course-stat-value" text="0" />
                                <Label fx:id="remainingCoursesMetaLabel" styleClass="my-course-stat-meta" text="courses left" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="my-courses-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="myCoursesContainer" hgap="18.0" prefWrapLength="1100.0" styleClass="my-courses-grid" vgap="18.0">
                            <padding><Insets bottom="28.0" left="4.0" right="10.0" top="4.0" /></padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
