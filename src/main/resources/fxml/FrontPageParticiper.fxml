<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edukids.edukids3a.ui.MainController" fx:id="paneFrontPageParticiper"
      spacing="0" styleClass="front-root" VBox.vgrow="ALWAYS" visible="false" managed="false">
    <VBox styleClass="front-hero">
        <Label text="Participer à l'événement" styleClass="hero-title"/>
        <Label fx:id="lblParticiperBreadcrumb" text="Événements • Réservation" styleClass="hero-breadcrumb"
               wrapText="true"/>
    </VBox>
    <ScrollPane fitToWidth="true" styleClass="cards-scroll" VBox.vgrow="ALWAYS">
        <StackPane styleClass="front-participer-scroll-wrap" alignment="TOP_CENTER">
            <VBox spacing="16.0" styleClass="front-participer-inner" maxWidth="720.0">
                <padding>
                    <Insets bottom="28.0" left="12.0" right="12.0" top="8.0"/>
                </padding>
                <HBox styleClass="resa-dialog-header" alignment="CENTER_LEFT">
                    <padding>
                        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
                    </padding>
                    <Label text="Inscription" styleClass="resa-dialog-header-title"/>
                </HBox>
                <VBox spacing="8.0" styleClass="form-section-card">
                    <Label fx:id="lblParticiperEvTitre" styleClass="resa-dialog-event-title" wrapText="true"/>
                    <Label fx:id="lblParticiperEvMeta" styleClass="resa-dialog-meta" wrapText="true"/>
                    <Label fx:id="lblParticiperEvLieu" styleClass="resa-dialog-meta" wrapText="true" managed="false"
                           visible="false"/>
                    <Label fx:id="lblParticiperEvPlaces" styleClass="resa-dialog-meta" wrapText="true" managed="false"
                           visible="false"/>
                </VBox>
                <Separator/>
                <GridPane fx:id="gridParticiperForm" hgap="14.0" vgap="12.0" styleClass="resa-dialog-form">
                    <columnConstraints>
                        <ColumnConstraints minWidth="72.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="38.0"/>
                        <ColumnConstraints minWidth="72.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="38.0"/>
                    </columnConstraints>
                    <Label text="Nom" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfParticiperNom" styleClass="search-field" GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>
                    <Label text="Prénom" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfParticiperPrenom" styleClass="search-field" GridPane.columnIndex="3"
                               GridPane.rowIndex="0"/>
                    <Label text="E-mail" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfParticiperEmail" styleClass="search-field" GridPane.columnIndex="1"
                               GridPane.columnSpan="3" GridPane.rowIndex="1"/>
                    <Label text="Téléphone" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="tfParticiperTel" styleClass="search-field" GridPane.columnIndex="1"
                               GridPane.columnSpan="3" GridPane.rowIndex="2"/>
                    <Label text="Adultes" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Spinner fx:id="spParticiperAdultes" editable="true" styleClass="spinner-time-dark"
                             GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Enfants" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                    <Spinner fx:id="spParticiperEnfants" editable="true" styleClass="spinner-time-dark"
                             GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                </GridPane>
                <VBox styleClass="resa-dialog-info-box" spacing="4.0">
                    <Label fx:id="lblParticiperTotal" styleClass="resa-dialog-info-total"
                           text="Total de places : 1"/>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="front-participer-actions">
                    <Button fx:id="btnParticiperRetour" mnemonicParsing="false" onAction="#onFrontParticiperRetour"
                            text="Retour" styleClass="button-secondary"/>
                    <Button fx:id="btnParticiperConfirmer" mnemonicParsing="false"
                            onAction="#onFrontParticiperConfirmer" text="Confirmer la réservation"
                            styleClass="btn-participer"/>
                </HBox>
            </VBox>
        </StackPane>
    </ScrollPane>
</VBox>
