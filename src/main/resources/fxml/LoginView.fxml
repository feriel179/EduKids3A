<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="rootPane" alignment="CENTER" spacing="0"
      fx:controller="com.edukids.edukids3a.ui.LoginController"
      styleClass="login-rami-root" prefWidth="900.0" prefHeight="600.0"
      stylesheets="@../css/edukids.css">

    <HBox alignment="CENTER" VBox.vgrow="ALWAYS">

        <VBox alignment="CENTER" spacing="20.0" styleClass="login-brand-panel" HBox.hgrow="ALWAYS"
              prefWidth="450.0">
            <Label text="EduKids" styleClass="brand-title"/>
            <Label text="Bienvenue !" styleClass="brand-subtitle"/>
            <Label text="Plateforme éducative" styleClass="brand-tagline"/>
            <Region prefHeight="20.0"/>
            <Label text="Événements &amp; programmes" styleClass="brand-tagline"/>
        </VBox>

        <VBox alignment="CENTER" spacing="20.0" styleClass="login-form-panel" HBox.hgrow="ALWAYS"
              prefWidth="450.0">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0"/>
            </padding>

            <Label text="Connexion" styleClass="form-title"/>
            <Label text="Connectez-vous avec votre compte (e-mail et mot de passe)." styleClass="form-subtitle"
                   wrapText="true"/>

            <VBox spacing="15.0" maxWidth="320.0">
                <Label text="Adresse e-mail" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="vous@exemple.com" styleClass="text-input"/>

                <Label text="Mot de passe" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Mot de passe" styleClass="text-input"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <CheckBox fx:id="rememberMeCheck" mnemonicParsing="false" text="Se souvenir de moi"
                              styleClass="check-input"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Mot de passe oublié ?" onAction="#handleForgotPassword" styleClass="link"/>
                </HBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <Button defaultButton="true" mnemonicParsing="false" text="Se connecter" onAction="#handleLogin"
                        styleClass="btn-primary" maxWidth="1.7976931348623157E308"/>

                <Separator/>

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Pas encore de compte ?" styleClass="text-muted"/>
                    <Hyperlink text="Créer un compte" onAction="#handleGoToRegister" styleClass="link-accent"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
