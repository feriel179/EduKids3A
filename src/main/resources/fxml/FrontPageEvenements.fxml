<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edukids.edukids3a.controller.MainController" fx:id="paneFrontPageEv" spacing="0" styleClass="front-root" VBox.vgrow="ALWAYS" visible="false" managed="false">
        <VBox styleClass="front-hero">
            <Label text="Nos événements" styleClass="hero-title"/>
            <Label text="Accueil • Événements" styleClass="hero-breadcrumb"/>
        </VBox>
        <HBox styleClass="front-toolbar">
            <TextField fx:id="tfFrontSearchEvenements" promptText="Rechercher un événement..."
                       styleClass="search-field" HBox.hgrow="SOMETIMES"/>
            <Button onAction="#onFrontRechercheEvenements" text="🔍" styleClass="btn-search"/>
            <ComboBox fx:id="cbFrontSortEvenements" styleClass="sort-combo" prefWidth="160.0"/>
            <Region prefWidth="8.0"/>
            <HBox spacing="4.0" styleClass="front-ev-view-toggles">
                <ToggleButton fx:id="toggleFrontEvListe" mnemonicParsing="false" text="Liste"
                              styleClass="mode-toggle" selected="true"/>
                <ToggleButton fx:id="toggleFrontEvCalendrier" mnemonicParsing="false" text="Calendrier"
                              styleClass="mode-toggle"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblFrontEvenementsCount" text="0 événement(s)" styleClass="front-counter"/>
        </HBox>
        <StackPane VBox.vgrow="ALWAYS">
            <VBox fx:id="boxFrontEvList" spacing="0" VBox.vgrow="ALWAYS">
                <StackPane VBox.vgrow="ALWAYS">
                    <ScrollPane fitToWidth="true" styleClass="cards-scroll" VBox.vgrow="ALWAYS">
                        <FlowPane fx:id="flowEvenementsCards" styleClass="cards-flow"/>
                    </ScrollPane>
                    <Label fx:id="lblEmptyFrontEvenements" managed="false" visible="false"
                           text="Aucun événement à afficher."
                           styleClass="empty-state-overlay" wrapText="true" maxWidth="420.0"
                           textAlignment="CENTER" mouseTransparent="true"
                           StackPane.alignment="CENTER"/>
                </StackPane>
            </VBox>
            <VBox fx:id="boxFrontEvCalendar" spacing="12.0" visible="false" managed="false"
                  styleClass="front-calendar-root" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER" spacing="20.0" styleClass="front-calendar-nav">
                    <Button fx:id="btnFrontCalPrev" mnemonicParsing="false" text="‹ Mois précédent"
                            onAction="#onFrontCalPrevMonth" styleClass="button,button-secondary"/>
                    <Label fx:id="lblFrontCalMonthTitle" styleClass="front-calendar-month-title"/>
                    <Button fx:id="btnFrontCalNext" mnemonicParsing="false" text="Mois suivant ›"
                            onAction="#onFrontCalNextMonth" styleClass="button,button-secondary"/>
                </HBox>
                <ScrollPane fitToWidth="true" styleClass="front-calendar-scroll" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="gridFrontEvenementsCalendar" styleClass="front-calendar-grid"
                              hgap="6.0" vgap="6.0"/>
                </ScrollPane>
            </VBox>
            <VBox fx:id="boxFrontEvDetail" visible="false" managed="false" spacing="0"
                  styleClass="detail-root-outer" VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="spFrontEvDetail" fitToWidth="true" pannable="false"
                            styleClass="detail-scroll-pane" VBox.vgrow="ALWAYS">
                    <VBox fx:id="boxFrontDetailScrollContent" spacing="16" styleClass="detail-content">
                        <Button text="← Retour aux événements" onAction="#onFrontRetourListeEvenements"
                                styleClass="detail-back"/>
                        <StackPane fx:id="detailHeroImgWrap" styleClass="detail-hero-img-wrap">
                            <ImageView fx:id="imgFrontDetailEvenement" fitWidth="900.0"
                                       fitHeight="280.0" preserveRatio="true" smooth="true"/>
                            <Label fx:id="lblFrontDetailImagePlaceholder"
                                   text="Pas d'image pour cet événement"
                                   styleClass="detail-hero-placeholder" wrapText="true"
                                   maxWidth="480.0" textAlignment="CENTER"
                                   mouseTransparent="true" StackPane.alignment="CENTER"/>
                        </StackPane>
                        <Label fx:id="lblFrontDetailTitre" styleClass="detail-title" wrapText="true"/>
                        <FlowPane fx:id="boxFrontDetailBadges" hgap="10" vgap="10"
                                  styleClass="detail-badges-flow"/>
                        <VBox spacing="8.0" styleClass="detail-section">
                            <Label text="Places &amp; durée" styleClass="detail-section-title"/>
                            <Label fx:id="lblFrontDetailPlacesRestantes" wrapText="true" styleClass="detail-description"/>
                            <Label fx:id="lblFrontDetailDuree" wrapText="true" styleClass="detail-description"/>
                        </VBox>
                        <VBox fx:id="boxFrontDetailMapWrap" spacing="6.0" styleClass="detail-section">
                            <Label text="Carte (Google Maps)" styleClass="detail-section-title"/>
                            <Label fx:id="lblFrontDetailMapLocation" wrapText="true" styleClass="detail-description"/>
                            <StackPane fx:id="detailMapFrame" maxWidth="1.7976931348623157E308" styleClass="detail-map-frame">
                                <ImageView fx:id="imgFrontDetailMap"
                                           fitHeight="360.0"
                                           preserveRatio="false"
                                           smooth="true"/>
                            </StackPane>
                        </VBox>
                        <VBox styleClass="detail-section" spacing="10">
                            <Label text="Description de l'événement" styleClass="detail-section-title"/>
                            <Label fx:id="lblFrontDetailDescription" wrapText="true"
                                   styleClass="detail-description"/>
                        </VBox>
                        <Label fx:id="lblFrontDetailProgrammeInfo" wrapText="true"
                               styleClass="detail-info-banner"/>
                        <VBox fx:id="boxFrontDetailProgramme" visible="false" managed="false"
                              spacing="14" styleClass="detail-section">
                            <Label text="Programme" styleClass="detail-section-title"/>
                            <Label fx:id="lblFrontDetailPause" wrapText="true"
                                   styleClass="detail-programme-pause"/>
                            <VBox spacing="6" styleClass="detail-field-block">
                                <Label text="Activités" styleClass="detail-field-label"/>
                                <Label fx:id="lblFrontDetailActivites" wrapText="true"
                                       styleClass="detail-description"/>
                            </VBox>
                            <VBox spacing="6" styleClass="detail-field-block">
                                <Label text="Documents requis" styleClass="detail-field-label"/>
                                <Label fx:id="lblFrontDetailDocs" wrapText="true"
                                       styleClass="detail-description"/>
                            </VBox>
                            <VBox spacing="6" styleClass="detail-field-block">
                                <Label text="Matériels requis" styleClass="detail-field-label"/>
                                <Label fx:id="lblFrontDetailMateriels" wrapText="true"
                                       styleClass="detail-description"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </StackPane>
</VBox>
