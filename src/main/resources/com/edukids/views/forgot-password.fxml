<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.edukids.controllers.ForgotPasswordController"
      styleClass="login-root" prefWidth="500" prefHeight="500">

    <VBox alignment="CENTER" spacing="20" styleClass="login-form-panel" VBox.vgrow="ALWAYS">
        <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

        <Label text="Forgot Password" styleClass="form-title"/>
        <Label text="Enter your email to receive a verification code" styleClass="form-subtitle" wrapText="true" alignment="CENTER"/>

        <VBox spacing="15" maxWidth="350">
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-input"/>

            <Button fx:id="sendCodeBtn" text="Send Code" onAction="#handleSendCode" styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
            <Label fx:id="successLabel" styleClass="success-label" wrapText="true"/>

            <Label text="Verification Code" styleClass="field-label"/>
            <TextField fx:id="otpField" promptText="Enter 6-digit code" styleClass="text-input"
                       visible="false" managed="false"/>

            <Button fx:id="verifyBtn" text="Verify &amp; Reset" onAction="#handleVerifyCode"
                    styleClass="btn-primary" maxWidth="Infinity" visible="false" managed="false"/>

            <Separator/>

            <HBox alignment="CENTER">
                <Hyperlink text="Back to Login" onAction="#handleBackToLogin" styleClass="link-accent"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
