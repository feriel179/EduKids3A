<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.edukids.controllers.LoginController"
      styleClass="login-root" prefWidth="900" prefHeight="600">

    <HBox alignment="CENTER" VBox.vgrow="ALWAYS">

        <!-- Left Panel - Branding -->
        <VBox alignment="CENTER" spacing="20" styleClass="login-brand-panel" HBox.hgrow="ALWAYS"
              prefWidth="450">
            <Label text="EduKids" styleClass="brand-title"/>
            <Label text="Welcome back!" styleClass="brand-subtitle"/>
            <Label text="Educational Platform for Children" styleClass="brand-tagline"/>
            <Region prefHeight="20"/>
            <Label text="4k+ Students already learning" styleClass="brand-tagline"/>
        </VBox>

        <!-- Right Panel - Login Form -->
        <VBox alignment="CENTER" spacing="20" styleClass="login-form-panel" HBox.hgrow="ALWAYS"
              prefWidth="450">
            <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

            <Label text="Sign In" styleClass="form-title"/>
            <Label text="Nice to see you! Please log in with your account." styleClass="form-subtitle" wrapText="true"/>

            <VBox spacing="15" maxWidth="320">
                <Label text="Email address" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="E-mail" styleClass="text-input"/>

                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-input"/>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <CheckBox fx:id="rememberMeCheck" text="Remember me" styleClass="check-input"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword" styleClass="link"/>
                </HBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <Button text="Sign In" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>

                <Separator/>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Don't have an account?" styleClass="text-muted"/>
                    <Hyperlink text="Sign Up" onAction="#handleGoToRegister" styleClass="link-accent"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
