<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.edukids.controllers.ResetPasswordController"
      styleClass="login-root" prefWidth="500" prefHeight="450">

    <VBox alignment="CENTER" spacing="20" styleClass="login-form-panel" VBox.vgrow="ALWAYS">
        <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

        <Label text="Reset Password" styleClass="form-title"/>
        <Label text="Create a new secure password" styleClass="form-subtitle"/>

        <VBox spacing="15" maxWidth="350">
            <Label text="New Password" styleClass="field-label"/>
            <PasswordField fx:id="newPasswordField" promptText="Min 8 chars, 1 digit, 1 uppercase" styleClass="text-input"/>

            <Label text="Confirm Password" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="text-input"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button text="Reset Password" onAction="#handleResetPassword" styleClass="btn-primary" maxWidth="Infinity"/>

            <Separator/>

            <HBox alignment="CENTER">
                <Hyperlink text="Back to Login" onAction="#handleBackToLogin" styleClass="link-accent"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
